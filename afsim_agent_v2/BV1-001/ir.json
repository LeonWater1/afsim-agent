{
  "schema_version": "afsim_ir_v1",
  "scenario": {
    "name": "acoustic_simple_demo",
    "description": "Minimal acoustic detection scenario.",
    "duration": {
      "value": 120,
      "unit": "sec"
    },
    "domains": [
      "surface"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "blue_start",
      "kind": "point",
      "position": {
        "lat": "30.67n",
        "lon": "104.07e"
      }
    },
    {
      "id": "red_contact",
      "kind": "point",
      "position": {
        "lat": "30.69n",
        "lon": "104.11e"
      }
    }
  ],
  "components": {
    "sensors": [
      {
        "id": "acoustic_sensor_basic",
        "role": "acoustic_detection",
        "type_hint": "acoustic_sensor",
        "parameters": {
          "mode": "passive"
        }
      }
    ]
  },
  "entities": [
    {
      "id": "blue_sensor_unit",
      "role": "sensor_platform",
      "side": "blue",
      "quantity": 1,
      "domain": "surface",
      "platform_type_hint": "acoustic_sensor_platform",
      "component_refs": [
        "acoustic_sensor_basic"
      ],
      "initial_location_ref": "blue_start"
    },
    {
      "id": "red_target_unit",
      "role": "target",
      "side": "red",
      "quantity": 1,
      "domain": "surface",
      "platform_type_hint": "acoustic_target",
      "initial_location_ref": "red_contact"
    }
  ],
  "tasks": [
    {
      "id": "detect_target",
      "type": "detect",
      "assignee_refs": [
        "blue_sensor_unit"
      ],
      "target_refs": [
        "red_target_unit"
      ],
      "parameters": {
        "priority": "primary"
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "scenario.duration",
      "entities.side",
      "entities.quantity"
    ]
  },
  "expected_events": [
    {
      "id": "target_detected",
      "type": "detection",
      "actor_refs": [
        "blue_sensor_unit",
        "red_target_unit"
      ],
      "success_condition": "Blue sensing platform detects the target during scenario runtime."
    }
  ]
}
