    "duration": {
      "value": 240,
      "unit": "sec"
    },
    "domains": [
      "air",
      "ground"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "designator_location",
      "kind": "point",
      "position": {
        "lat": "30.65n",
        "lon": "104.10e",
        "altitude": {
          "value": 0,
          "unit": "m"
        }
      }
    },
    {
      "id": "fighter_spawn",
      "kind": "point",
      "position": {
        "lat": "30.50n",
        "lon": "104.00e",
        "altitude": {
          "value": 3000,
          "unit": "m"
        }
      }
    },
    {
      "id": "target_position",
      "kind": "point",
      "position": {
        "lat": "30.70n",
        "lon": "104.15e",
        "altitude": {
          "value": 0,
          "unit": "m"
        }
      }
    }
  ],
  "routes": [
    {
      "id": "attack_route",
      "kind": "transit",
      "waypoints": [
        {
          "location_ref": "fighter_spawn",
          "speed": {
            "value": 250,
            "unit": "m/sec"
          }
        },
        {
          "position": {
            "lat": "30.68n",
            "lon": "104.12e",
            "altitude": {
              "value": 3500,
              "unit": "m"
            }
          },
          "speed": {
            "value": 250,
            "unit": "m/sec"
          }
        }
      ]
    }
  ],
  "components": {
    "movers": [
      {
        "id": "air_mover",
        "type_hint": "air_mover"
      },
      {
        "id": "ground_mover",
        "type_hint": "ground_mover"
      }
    ],
    "sensors": [
      {
        "id": "laser_designator",
        "role": "target_designation",
        "type_hint": "laser_designator_sensor",
        "parameters": {
          "mode": "designate"
        }
      }
    ],
    "weapons": [
      {
        "id": "lg_bomb",
        "role": "air_to_ground_weapon",
        "type_hint": "laser_guided_bomb",
        "parameters": {
          "guidance": "laser"
        }
      }
    ],
    "processors": [
      {
        "id": "coop_attack_processor",
        "role": "cooperative_engagement",
        "type_hint": "cooperative_engagement_processor"
      }
    ],
    "comms": [
      {
        "id": "datalink",
        "role": "coordination",
        "type_hint": "datalink"
      }
    ]
  },
  "entities": [
    {
      "id": "blue_designator_unit",
      "role": "designator",
      "side": "blue",
      "quantity": 1,
      "domain": "ground",
      "platform_type_hint": "ground_designator",
      "component_refs": [
        "ground_mover",
        "laser_designator",
        "datalink"
      ],
      "initial_location_ref": "designator_location"
    },
    {
      "id": "blue_attack_aircraft",
      "role": "strike_fighter",
      "side": "blue",
      "quantity": 1,
      "domain": "air",
      "platform_type_hint": "fighter_aircraft",
      "component_refs": [
        "air_mover",
        "lg_bomb",
        "coop_attack_processor",
        "datalink"
      ],
      "initial_location_ref": "fighter_spawn",
      "route_ref": "attack_route"
    },
    {
      "id": "red_target",
      "role": "target",
      "side": "red",
      "quantity": 1,
      "domain": "ground",
      "platform_type_hint": "ground_target",
      "component_refs": [
        "ground_mover"
      ],
      "initial_location_ref": "target_position"
    }
  ],
  "tasks": [
    {
      "id": "designate_target",
      "type": "designate",
      "assignee_refs": [
        "blue_designator_unit"
      ],
      "target_refs": [
        "red_target"
      ],
      "parameters": {
        "laser_code": 1111
      }
    },
    {
      "id": "strike_target",
      "type": "air_attack",
      "assignee_refs": [
        "blue_attack_aircraft"
      ],
      "target_refs": [
        "red_target"
      ],
      "parameters": {
        "weapon": "lg_bomb",
        "cooperative": true
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "entities.quantity",
      "entities.side",
      "tasks"
    ]
  },
  "expected_events": [
    {
      "id": "target_lased",
      "type": "designation",
      "actor_refs": [
        "blue_designator_unit",
        "red_target"
      ],
      "success_condition": "激光指示器持续照射目标，为制导武器提供末端引导。"
    },
    {
      "id": "weapon_on_target",
      "type": "weapon_impact",
      "actor_refs": [
        "blue_attack_aircraft",
        "red_target"
      ],
      "success_condition": "激光制导炸弹命中目标。"
    }
  ]
}
