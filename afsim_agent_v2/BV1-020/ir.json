{
  "schema_version": "afsim_ir_v1",
  "scenario": {
    "name": "spot_jamming_suppression",
    "description": "基于 electronic_warfare/spot_jamming 的点频压制干扰场景。Spot jamming suppression scenario where a jammer focuses energy on a specific frequency to degrade radar performance.",
    "duration": {
      "value": 300,
      "unit": "sec"
    },
    "domains": [
      "ground"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "radar_site",
      "kind": "point",
      "position": {
        "lat": "30.67n",
        "lon": "104.07e",
        "altitude": {
          "value": 0,
          "unit": "m"
        }
      }
    },
    {
      "id": "jammer_site",
      "kind": "point",
      "position": {
        "lat": "30.69n",
        "lon": "104.11e",
        "altitude": {
          "value": 0,
          "unit": "m"
        }
      }
    }
  ],
  "components": {
    "movers": [
      {
        "id": "ground_mover",
        "role": "ground_movement",
        "type_hint": "ground_mover"
      }
    ],
    "sensors": [
      {
        "id": "radar_sensor",
        "role": "radar_detection",
        "type_hint": "radar"
      }
    ],
    "processors": [
      {
        "id": "spot_jammer_processor",
        "role": "spot_jamming",
        "type_hint": "jammer",
        "parameters": {
          "jamming_mode": "spot"
        }
      }
    ]
  },
  "entities": [
    {
      "id": "blue_radar",
      "role": "radar_platform",
      "side": "blue",
      "quantity": 1,
      "domain": "ground",
      "platform_type_hint": "radar_platform",
      "component_refs": [
        "ground_mover",
        "radar_sensor"
      ],
      "initial_location_ref": "radar_site"
    },
    {
      "id": "red_jammer",
      "role": "jammer_platform",
      "side": "red",
      "quantity": 1,
      "domain": "ground",
      "platform_type_hint": "jammer_platform",
      "component_refs": [
        "ground_mover",
        "spot_jammer_processor"
      ],
      "initial_location_ref": "jammer_site"
    }
  ],
  "tasks": [
    {
      "id": "jam_radar",
      "type": "spot_jamming",
      "assignee_refs": [
        "red_jammer"
      ],
      "target_refs": [
        "blue_radar"
      ],
      "parameters": {
        "jamming_type": "spot",
        "priority": "primary"
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "scenario.duration",
      "entities.side",
      "entities.quantity",
      "tasks"
    ]
  },
  "expected_events": [
    {
      "id": "radar_jammed",
      "type": "jamming_effect",
      "actor_refs": [
        "red_jammer",
        "blue_radar"
      ],
      "success_condition": "The jammer suppresses the radar's detection capability during the scenario."
    }
  ]
}
