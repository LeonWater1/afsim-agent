{
  "schema_version": "afsim_ir_v1",
  "scenario": {
    "name": "esm_detect_radar",
    "description": "ESM 探测雷达辐射源场景。",
    "duration": {
      "value": 200,
      "unit": "sec"
    },
    "domains": [
      "air",
      "ground"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "blue_start",
      "kind": "point",
      "position": {
        "lat": "30.67n",
        "lon": "104.07e",
        "altitude": {
          "value": 5000,
          "unit": "m"
        }
      }
    },
    {
      "id": "red_radar_site",
      "kind": "point",
      "position": {
        "lat": "30.70n",
        "lon": "104.10e",
        "altitude": {
          "value": 0,
          "unit": "m"
        }
      }
    }
  ],
  "components": {
    "movers": [
      {
        "id": "air_mover",
        "role": "air_mover",
        "type_hint": "air_mover"
      }
    ],
    "sensors": [
      {
        "id": "esm_sensor",
        "role": "esm_receiver",
        "type_hint": "esm_sensor"
      },
      {
        "id": "radar_sensor",
        "role": "radar_emitter",
        "type_hint": "radar_sensor"
      }
    ]
  },
  "entities": [
    {
      "id": "blue_esm_platform",
      "role": "esm_receiver",
      "side": "blue",
      "quantity": 1,
      "domain": "air",
      "platform_type_hint": "electronic_warfare_aircraft",
      "component_refs": [
        "air_mover",
        "esm_sensor"
      ],
      "initial_location_ref": "blue_start"
    },
    {
      "id": "red_radar_emitter",
      "role": "radar_emitter",
      "side": "red",
      "quantity": 1,
      "domain": "ground",
      "platform_type_hint": "ground_radar_site",
      "component_refs": [
        "radar_sensor"
      ],
      "initial_location_ref": "red_radar_site"
    }
  ],
  "tasks": [
    {
      "id": "detect_radar",
      "type": "detect",
      "assignee_refs": [
        "blue_esm_platform"
      ],
      "target_refs": [
        "red_radar_emitter"
      ],
      "parameters": {
        "detection_mode": "esm"
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "entities.quantity",
      "entities.side",
      "tasks"
    ]
  },
  "expected_events": [
    {
      "id": "esm_detection",
      "type": "detection",
      "actor_refs": [
        "blue_esm_platform",
        "red_radar_emitter"
      ],
      "success_condition": "Blue ESM platform detects the red radar emitter during scenario runtime."
    }
  ]
}
