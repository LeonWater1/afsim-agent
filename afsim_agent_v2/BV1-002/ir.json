{
  "schema_version": "afsim_ir_v1",
  "scenario": {
    "name": "acoustic_moving_target_demo",
    "description": "Acoustic detection scenario with a moving underwater target.",
    "duration": {
      "value": 300,
      "unit": "sec"
    },
    "domains": [
      "subsurface"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "blue_start",
      "kind": "point",
      "position": {
        "lat": "30.67n",
        "lon": "104.07e",
        "altitude": {
          "value": -50,
          "unit": "m"
        }
      }
    },
    {
      "id": "red_start",
      "kind": "point",
      "position": {
        "lat": "30.69n",
        "lon": "104.11e",
        "altitude": {
          "value": -40,
          "unit": "m"
        }
      }
    },
    {
      "id": "red_mid",
      "kind": "point",
      "position": {
        "lat": "30.75n",
        "lon": "104.15e",
        "altitude": {
          "value": -45,
          "unit": "m"
        }
      }
    }
  ],
  "routes": [
    {
      "id": "target_route",
      "kind": "transit",
      "waypoints": [
        {
          "location_ref": "red_start",
          "speed": {
            "value": 5,
            "unit": "m/sec"
          }
        },
        {
          "location_ref": "red_mid",
          "speed": {
            "value": 5,
            "unit": "m/sec"
          }
        }
      ]
    }
  ],
  "components": {
    "movers": [
      {
        "id": "target_mover",
        "role": "underwater_mover",
        "type_hint": "underwater_mover"
      }
    ],
    "sensors": [
      {
        "id": "acoustic_sensor_basic",
        "role": "acoustic_detection",
        "type_hint": "acoustic_sensor",
        "parameters": {
          "mode": "passive"
        }
      }
    ]
  },
  "entities": [
    {
      "id": "blue_sensor_unit",
      "role": "sensor_platform",
      "side": "blue",
      "quantity": 1,
      "domain": "subsurface",
      "platform_type_hint": "acoustic_sensor_platform",
      "component_refs": [
        "acoustic_sensor_basic"
      ],
      "initial_location_ref": "blue_start"
    },
    {
      "id": "red_target_unit",
      "role": "target",
      "side": "red",
      "quantity": 1,
      "domain": "subsurface",
      "platform_type_hint": "acoustic_target",
      "component_refs": [
        "target_mover"
      ],
      "initial_location_ref": "red_start",
      "route_ref": "target_route"
    }
  ],
  "tasks": [
    {
      "id": "detect_target",
      "type": "detect",
      "assignee_refs": [
        "blue_sensor_unit"
      ],
      "target_refs": [
        "red_target_unit"
      ],
      "parameters": {
        "priority": "primary"
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "scenario.duration",
      "entities.side",
      "entities.quantity"
    ]
  },
  "expected_events": [
    {
      "id": "target_detected",
      "type": "detection",
      "actor_refs": [
        "blue_sensor_unit",
        "red_target_unit"
      ],
      "success_condition": "Blue sensing platform detects the moving target during scenario runtime."
    }
  ]
}
