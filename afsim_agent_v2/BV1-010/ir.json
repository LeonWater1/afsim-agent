{
  "schema_version": "afsim_ir_v1",
  "scenario": {
    "name": "bearing_only_detection_tracking",
    "description": "基于 bearing_only/test_run 生成的仅方位探测/跟踪场景。Bearing-only detection and tracking demo.",
    "duration": {
      "value": 300,
      "unit": "sec"
    },
    "domains": [
      "air"
    ],
    "outputs": [
      "event_pipe"
    ]
  },
  "sides": [
    {
      "id": "blue",
      "display_name": "Blue"
    },
    {
      "id": "red",
      "display_name": "Red"
    }
  ],
  "locations": [
    {
      "id": "blue_start",
      "kind": "point",
      "position": {
        "lat": "30.67n",
        "lon": "104.07e",
        "altitude": {
          "value": 5000,
          "unit": "m"
        }
      }
    },
    {
      "id": "red_start",
      "kind": "point",
      "position": {
        "lat": "30.92n",
        "lon": "104.37e",
        "altitude": {
          "value": 5000,
          "unit": "m"
        }
      }
    }
  ],
  "components": {
    "sensors": [
      {
        "id": "esm_sensor",
        "role": "bearing_only_detection",
        "type_hint": "esm_receiver",
        "parameters": {
          "mode": "passive",
          "measurements": [
            "azimuth"
          ]
        }
      },
      {
        "id": "red_radar",
        "role": "emitter",
        "type_hint": "airborne_radar",
        "parameters": {
          "mode": "active"
        }
      }
    ],
    "processors": [
      {
        "id": "bearing_tracker",
        "role": "bearing_only_tracking",
        "type_hint": "bearing_only_tracker",
        "parameters": {
          "algorithm": "MHT",
          "fusion_mode": "passive_only"
        }
      }
    ]
  },
  "entities": [
    {
      "id": "blue_sensor_platform",
      "role": "reconnaissance",
      "side": "blue",
      "quantity": 1,
      "domain": "air",
      "platform_type_hint": "electronic_surveillance_aircraft",
      "component_refs": [
        "esm_sensor",
        "bearing_tracker"
      ],
      "initial_location_ref": "blue_start"
    },
    {
      "id": "red_target_emitter",
      "role": "emitter_target",
      "side": "red",
      "quantity": 1,
      "domain": "air",
      "platform_type_hint": "fighter_aircraft",
      "component_refs": [
        "red_radar"
      ],
      "initial_location_ref": "red_start"
    }
  ],
  "tasks": [
    {
      "id": "track_red_emitter",
      "type": "track",
      "assignee_refs": [
        "blue_sensor_platform"
      ],
      "target_refs": [
        "red_target_emitter"
      ],
      "parameters": {
        "mode": "bearing_only",
        "priority": "primary"
      }
    }
  ],
  "constraints": {
    "unit_system": "afsim_mixed",
    "coordinate_format": "lat_lon_dir",
    "required_fields": [
      "entities.quantity",
      "entities.side",
      "tasks"
    ]
  },
  "expected_events": [
    {
      "id": "bearing_track_established",
      "type": "track",
      "actor_refs": [
        "blue_sensor_platform",
        "red_target_emitter"
      ],
      "success_condition": "Blue ESM platform tracks the red target using bearing-only measurements."
    }
  ],
  "grounding_hints": [
    {
      "label": "Bearing-only ESM sensor",
      "target_kind": "sensor",
      "candidate_types": [
        "ESMReceiver",
        "PassiveDirectionFinder"
      ],
      "notes": "Passive sensor measuring azimuth only; requires target to emit."
    },
    {
      "label": "Red airborne radar emitter",
      "target_kind": "sensor",
      "candidate_types": [
        "AirborneRadar",
        "Emitter"
      ],
      "notes": "Active radar on red fighter, serves as emission source for ESM."
    },
    {
      "label": "Bearing-only tracker processor",
      "target_kind": "processor",
      "candidate_types": [
        "BearingOnlyTracker",
        "PassiveFusion"
      ],
      "notes": "Processes bearing measurements into tracks."
    },
    {
      "label": "Blue electronic surveillance aircraft",
      "target_kind": "platform",
      "candidate_types": [
        "RC135",
        "EP3",
        "ElectronicSurveillanceAircraft"
      ],
      "notes": "Reconnaissance platform with passive ESM capability."
    },
    {
      "label": "Red emitter aircraft",
      "target_kind": "platform",
      "candidate_types": [
        "Fighter",
        "Su27",
        "J11"
      ],
      "notes": "Target aircraft emitting radar."
    }
  ]
}
