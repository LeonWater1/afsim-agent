{
  "version": "evaluation_protocol_v1",
  "benchmark": "benchmark_v1",
  "task_scope": "A-type end-to-end tasks first, extensible to IR/Grounding/Repair stages",
  "metrics": [
    {
      "id": "ir_validity",
      "display_name": "IR Validity",
      "row_field": "ir_valid",
      "summary_field": "ir_validity_rate",
      "aggregation": "mean",
      "required_for": ["ir_only", "full_agent"],
      "optional_for": ["direct_prompt", "rag"]
    },
    {
      "id": "ir_accuracy",
      "display_name": "IR Accuracy",
      "row_field": "ir_accurate",
      "summary_field": "ir_accuracy_rate",
      "aggregation": "mean",
      "required_for": ["ir_only", "full_agent"],
      "optional_for": ["direct_prompt", "rag"]
    },
    {
      "id": "grounding_accuracy",
      "display_name": "Grounding Accuracy",
      "row_field": "grounding_correct",
      "summary_field": "grounding_accuracy_rate",
      "aggregation": "mean",
      "required_for": ["grounded", "full_agent"],
      "optional_for": ["direct_prompt", "rag", "ir_only"]
    },
    {
      "id": "script_correctness",
      "display_name": "Script Correctness",
      "row_field": "syntax_correct",
      "summary_field": "syntax_correct_rate",
      "aggregation": "mean",
      "required_for": ["direct_prompt", "rag", "ir_only", "full_agent"]
    },
    {
      "id": "static_pass_rate",
      "display_name": "Static Pass Rate",
      "row_field": "static_pass",
      "summary_field": "static_pass_rate",
      "aggregation": "mean",
      "required_for": ["direct_prompt", "rag", "ir_only", "full_agent"]
    },
    {
      "id": "semantic_match_rate",
      "display_name": "Semantic Match Rate",
      "row_field": "semantic_match",
      "summary_field": "semantic_match_rate",
      "aggregation": "mean",
      "required_for": ["direct_prompt", "rag", "ir_only", "full_agent"]
    },
    {
      "id": "repair_success_rate",
      "display_name": "Repair Success Rate",
      "row_field": "repair_success",
      "summary_field": "repair_success_rate",
      "aggregation": "mean",
      "required_for": ["repair", "full_agent"],
      "optional_for": ["direct_prompt", "rag", "ir_only"]
    },
    {
      "id": "mission_success_rate",
      "display_name": "mission.exe Success Rate",
      "row_field": "mission_status",
      "summary_field": "mission_success_rate",
      "aggregation": "pass_ratio",
      "required_for": ["direct_prompt", "rag", "ir_only", "full_agent"]
    }
  ],
  "row_contract": {
    "required": [
      "id",
      "generated_script",
      "mission_status"
    ],
    "recommended": [
      "syntax_correct",
      "static_pass",
      "semantic_match",
      "primary_error",
      "secondary_errors"
    ],
    "future_stage_fields": [
      "ir_valid",
      "ir_accurate",
      "grounding_correct",
      "repair_success"
    ]
  },
  "protocol_rules": {
    "refresh_static_from_generated_scripts": true,
    "mission_pass_value": "PASS",
    "null_metric_policy": "use null when the method does not expose the required stage artifact"
  }
}
